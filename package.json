{
  "name": "github-models-paperclip-adapter",
  "version": "0.5.0",
  "description": "Paperclip adapter that runs agents against GitHub's free Models API. No Copilot subscription needed — just a GitHub PAT with models:read scope.",
  "type": "module",
  "license": "MIT",
  "author": "Armani Cunningham",
  "repository": {
    "type": "git",
    "url": "https://github.com/acunningham-ship-it/github-models-paperclip-adapter"
  },
  "keywords": [
    "paperclip",
    "github-models",
    "ai-agent",
    "adapter",
    "free-llm",
    "openai-compatible"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./ui-parser": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "^2026.416.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": { "node": ">=20.0.0" },
  "paperclip": {
    "adapterType": "github_models",
    "adapterUiParser": "1"
  }
}
